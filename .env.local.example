# Copie este arquivo para ".env.local" e preencha com os valores do seu projeto Supabase.
# (No painel do Supabase: Project Settings > API)

# URL do projeto (ex: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" (pode ficar exposta no navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave secreta "service_role" (NUNCA exponha — só no servidor)
SUPABASE_SERVICE_ROLE_KEY=

# Senha que VOCÊ usa para entrar na área da fotógrafa
ADMIN_PASSWORD=troque-esta-senha

# Segredo aleatório para assinar o login (gere qualquer texto longo e aleatório)
AUTH_SECRET=cole-aqui-um-texto-longo-aleatorio

# --- Aviso por e-mail quando a cliente aprova (Resend) ---
# Chave da API do Resend (https://resend.com > API Keys)
RESEND_API_KEY=
# Para qual e-mail mandar o aviso
NOTIFY_EMAIL=seu-email@exemplo.com
# Endereço público do site (em produção, a URL da Vercel)
APP_URL=http://localhost:3939
# Remetente. Sem domínio próprio, use o de teste do Resend abaixo.
EMAIL_FROM=Ordem do Álbum <onboarding@resend.dev>
